{
  "name": "@loradb/lora-graph-canvas",
  "version": "0.11.5",
  "description": "React graph canvas for LoraDB. Unified 2D/3D force-directed component with a built-in tool palette for adding, connecting, selecting, and removing nodes.",
  "license": "BUSL-1.1",
  "packageManager": "yarn@4.5.1",
  "author": "LoraDB, Inc.",
  "homepage": "https://github.com/lora-db/lora/tree/main/packages/lora-graph-canvas#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lora-db/lora.git",
    "directory": "packages/lora-graph-canvas"
  },
  "bugs": {
    "url": "https://github.com/lora-db/lora/issues"
  },
  "keywords": [
    "lora",
    "loradb",
    "graph",
    "canvas",
    "react",
    "force-directed",
    "2d",
    "3d",
    "three"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/style.css"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "THIRD_PARTY.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src test",
    "lint:fix": "eslint src test --fix",
    "format": "prettier --write src test",
    "format:check": "prettier --check src test",
    "storybook": "storybook dev -p 6007",
    "build:storybook": "storybook build -o storybook-static"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "three": ">=0.150.0"
  },
  "dependencies": {
    "d3-array": "^3.2.0",
    "d3-drag": "^3.0.0",
    "d3-force-3d": "^3.0.0",
    "d3-scale": "^4.0.0",
    "d3-scale-chromatic": "^3.0.0",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "three-forcegraph": "^1.43.0",
    "three-render-objects": "^1.41.0"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.3.0",
    "@storybook/addon-interactions": "^8.3.0",
    "@storybook/addon-links": "^8.3.0",
    "@storybook/blocks": "^8.3.0",
    "@storybook/react": "^8.3.0",
    "@storybook/react-vite": "^8.3.0",
    "@storybook/test": "^8.3.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/three": "^0.182.0",
    "@vitejs/plugin-react": "^4.3.0",
    "jsdom": "^25.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "storybook": "^8.3.0",
    "three": "^0.182.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.2.0",
    "vitest": "^2.1.0"
  }
}
