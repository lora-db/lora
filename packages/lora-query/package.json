{
  "name": "@loradb/lora-query",
  "version": "0.11.3",
  "description": "React CodeMirror editor for the LoraDB Cypher dialect, backed by a WASM pest parser for validation and reformatting.",
  "license": "BUSL-1.1",
  "packageManager": "yarn@4.5.1",
  "author": "LoraDB, Inc.",
  "homepage": "https://github.com/lora-db/lora/tree/main/packages/lora-query#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lora-db/lora.git",
    "directory": "packages/lora-query"
  },
  "bugs": {
    "url": "https://github.com/lora-db/lora/issues"
  },
  "keywords": [
    "lora",
    "loradb",
    "cypher",
    "codemirror",
    "react",
    "editor",
    "wasm",
    "pest"
  ],
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./parser": {
      "types": "./dist/parser.d.ts",
      "import": "./dist/parser.js",
      "default": "./dist/parser.js"
    },
    "./styles.css": "./dist/style.css",
    "./wasm/*": "./wasm/*"
  },
  "files": [
    "dist/",
    "wasm/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build:wasm": "wasm-pack build . --target bundler --release --out-dir wasm",
    "postbuild:wasm": "node -e \"try { require('fs').rmSync('wasm/.gitignore'); } catch {}\" && node ./scripts/wasm-opt-size.mjs",
    "build:lib": "vite build",
    "build": "yarn build:wasm && yarn build:lib",
    "dev": "vite",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src test",
    "lint:fix": "eslint src test --fix",
    "format": "prettier --write src test",
    "format:check": "prettier --check src test",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build -o storybook-static"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.0",
    "@codemirror/commands": "^6.6.0",
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/language": "^6.10.0",
    "@codemirror/lint": "^6.8.0",
    "@codemirror/search": "^6.5.0",
    "@codemirror/state": "^6.4.0",
    "@codemirror/view": "^6.32.0",
    "@lezer/highlight": "^1.2.0"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.3.0",
    "@storybook/addon-interactions": "^8.3.0",
    "@storybook/addon-links": "^8.3.0",
    "@storybook/blocks": "^8.3.0",
    "@storybook/react": "^8.3.0",
    "@storybook/react-vite": "^8.3.0",
    "@storybook/test": "^8.3.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9.15.0",
    "jsdom": "^25.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "storybook": "^8.3.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.2.0",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^2.1.0"
  }
}
