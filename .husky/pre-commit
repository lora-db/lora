STAGED=$(git diff --cached --name-only --diff-filter=ACMR)

ANY_RUST=0
if printf '%s\n' "$STAGED" | grep -qE '\.rs$|^Cargo\.(toml|lock)$|^rust-toolchain\.toml$|^clippy\.toml$'; then
  ANY_RUST=1
fi

# Compute the affected-crate scope once, reused for clippy below.
# Output is one of:
#   "--workspace"                → broad change (Cargo.lock, root manifest, …)
#   "-p crateA -p crateB ..."    → reverse-dep closure of changed crates
#   ""                            → no testable crates touched
TARGETS=""
if [ "$ANY_RUST" = "1" ]; then
  TARGETS=$(node scripts/affected-crates.mjs)
fi

run_cargo_scoped() {
  # $1 = subcommand (e.g. "clippy"); $2... = trailing args
  cmd="$1"; shift
  case "$TARGETS" in
    --workspace)
      cargo $cmd --workspace --exclude lora-python --exclude lora_ruby "$@"
      ;;
    "")
      return 0
      ;;
    *)
      cargo $cmd $TARGETS "$@"
      ;;
  esac
}

# Lint passes are scoped to Rust changes — no point running fmt/clippy on
# a docs- or scripts-only commit. fmt-check is fast and global; clippy is
# scoped to the affected crates. Rust + binding test gates intentionally
# omitted: CI is the source of truth for those, pre-commit only runs lint.
if [ "$ANY_RUST" = "1" ]; then
  cargo fmt --all --check || exit 1
  run_cargo_scoped clippy -- -D warnings || exit 1
fi

# JS/TS lint pass. Runs whenever any JS/TS-ish file is staged.
ANY_JS_TS=0
if printf '%s\n' "$STAGED" | grep -qE '\.(ts|tsx|js|jsx|mjs|cjs)$'; then
  ANY_JS_TS=1
fi

if [ "$ANY_JS_TS" = "1" ]; then
  yarn lint || exit 1
fi
