{
  "name": "@loradb/lora-node",
  "version": "0.1.0",
  "description": "Node.js / TypeScript bindings for the Lora in-memory graph database",
  "license": "BUSL-1.1",
  "author": "LoraDB, Inc.",
  "homepage": "https://github.com/lora-db/lora#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lora-db/lora.git",
    "directory": "crates/lora-node"
  },
  "bugs": {
    "url": "https://github.com/lora-db/lora/issues"
  },
  "keywords": [
    "lora",
    "loradb",
    "graph",
    "cypher",
    "database",
    "embedded",
    "napi",
    "n-api"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "ts/native.js",
    "ts/native.d.ts",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "napi": {
    "name": "lora-node",
    "package": {
      "name": "@loradb/lora-node"
    },
    "triples": {
      "defaults": false,
      "additional": [
        "x86_64-unknown-linux-gnu",
        "aarch64-unknown-linux-gnu",
        "x86_64-apple-darwin",
        "aarch64-apple-darwin",
        "x86_64-pc-windows-msvc"
      ]
    }
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "sync:types": "node -e \"require('fs').copyFileSync('../shared-ts/types.ts','ts/types.ts')\"",
    "verify:types": "node -e \"const fs=require('fs'); const a=fs.readFileSync('../shared-ts/types.ts','utf8'); const b=fs.readFileSync('ts/types.ts','utf8'); if (a!==b) { console.error('ts/types.ts is out of sync with shared-ts/types.ts — run npm run sync:types'); process.exit(1);} \"",
    "prebuild": "npm run sync:types",
    "pretypecheck": "npm run sync:types",
    "pretest": "npm run sync:types",
    "build:native": "napi build --platform --release --js false",
    "build:native:debug": "napi build --platform --js false",
    "build:ts": "tsc -p tsconfig.json",
    "build": "npm run build:native && npm run build:ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "artifacts": "napi artifacts",
    "create-npm-dirs": "napi create-npm-dir -t .",
    "copy-license": "node -e \"const fs=require('fs'); try { fs.copyFileSync('../../LICENSE','LICENSE'); } catch (e) { if (e.code !== 'ENOENT') throw e; }\"",
    "prepack": "npm run sync:types && npm run copy-license && npm run build",
    "pack:dry": "npm pack --dry-run"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.4",
    "@types/node": "^22.7.4",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
