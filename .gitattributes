# Normalize line endings to LF on checkin, auto on checkout
* text=auto eol=lf

# Rust, TypeScript, JS, JSON, YAML, Markdown, TOML source
*.rs       text eol=lf
*.ts       text eol=lf
*.tsx      text eol=lf
*.js       text eol=lf
*.jsx      text eol=lf
*.json     text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.toml     text eol=lf
*.md       text eol=lf
*.pest     text eol=lf
*.py       text eol=lf
*.sh       text eol=lf
Cargo.lock text eol=lf

# Windows-only shells / scripts stay CRLF
*.ps1      text eol=crlf
*.bat      text eol=crlf
*.cmd      text eol=crlf

# Generated / vendored — collapse in GitHub diffs and exclude from language stats
package-lock.json linguist-generated=true
Cargo.lock        linguist-generated=true
**/dist/**        linguist-generated=true
**/pkg-node/**    linguist-generated=true
**/pkg-bundler/** linguist-generated=true
**/pkg-web/**     linguist-generated=true
apps/loradb.com/build/** linguist-generated=true

# Docs are not the primary language of the repo
docs/**                         linguist-documentation=true
apps/loradb.com/docs/**         linguist-documentation=true
apps/loradb.com/blog/**         linguist-documentation=true

# Binary artifacts
*.node     binary
*.wasm     binary
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.woff     binary
*.woff2    binary
*.ttf      binary
*.otf      binary
*.pdf      binary
